{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compliance report",
  "type": "object",
  "required": ["status", "checked_files", "risk_items", "claim_items", "summary"],
  "properties": {
    "status": { "enum": ["passed", "failed"] },
    "checked_files": { "type": "array", "items": { "type": "string" } },
    "risk_items": { "type": "array", "items": { "type": "object" } },
    "claim_items": { "type": "array", "items": { "type": "object" } },
    "summary": {
      "type": "object",
      "required": ["error_count", "warning_count"],
      "properties": {
        "error_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
