{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reference analysis",
  "type": "object",
  "required": [
    "reference_type",
    "duration_seconds",
    "aspect_ratio",
    "topic",
    "structure",
    "what_to_learn",
    "what_not_to_copy",
    "originality_plan"
  ],
  "properties": {
    "reference_type": { "enum": ["douyin_url", "local_video", "share_text"] },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "resolution": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    },
    "fps": { "type": "number", "minimum": 0 },
    "aspect_ratio": { "type": "string" },
    "topic": { "type": "string" },
    "structure": { "type": "array", "items": { "type": "object" } },
    "what_to_learn": { "type": "array", "items": { "type": "string" } },
    "what_not_to_copy": { "type": "array", "items": { "type": "string" } },
    "extracted_assets": { "type": "object" },
    "originality_plan": {
      "type": "object",
      "required": ["new_angle", "new_visuals", "new_script", "similarity_risk"],
      "properties": {
        "new_angle": { "type": "string" },
        "new_visuals": { "type": "string" },
        "new_script": { "type": "string" },
        "similarity_risk": { "enum": ["low", "medium", "high"] }
      }
    }
  }
}
