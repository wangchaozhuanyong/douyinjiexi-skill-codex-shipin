{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Copy package",
  "type": "object",
  "required": [
    "selected_topic",
    "title_options",
    "cover_text_options",
    "first_3_seconds_hook",
    "first_5_seconds_hook",
    "full_voiceover",
    "scene_captions",
    "on_screen_text",
    "retention_beats",
    "save_value",
    "publish_caption",
    "hashtags",
    "claim_ledger",
    "scores"
  ],
  "properties": {
    "selected_topic": { "type": "object" },
    "title_options": { "type": "array", "minItems": 3, "items": { "type": "string" } },
    "cover_text_options": { "type": "array", "minItems": 2, "items": { "type": "object" } },
    "first_3_seconds_hook": {
      "type": "object",
      "required": ["type", "line", "visual"],
      "properties": {
        "type": { "type": "string" },
        "line": { "type": "string" },
        "visual": { "type": "string" }
      }
    },
    "first_5_seconds_hook": {
      "type": "object",
      "required": ["line", "visual_changes"],
      "properties": {
        "line": { "type": "string" },
        "visual_changes": { "type": "array", "minItems": 2, "items": { "type": "string" } }
      }
    },
    "first_5_seconds_hooks": { "type": "array", "minItems": 2, "items": { "type": "object" } },
    "full_voiceover": { "type": "object", "required": ["target_duration", "speed", "text"] },
    "scene_captions": { "type": "array", "items": { "type": "object" } },
    "on_screen_text": { "type": "array", "items": { "type": "object" } },
    "retention_beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time_range", "type", "line", "visual"],
        "properties": {
          "time_range": { "type": "string" },
          "type": { "type": "string" },
          "line": { "type": "string" },
          "visual": { "type": "string" }
        }
      }
    },
    "save_value": {
      "type": "object",
      "required": ["reason", "reusable_asset"],
      "properties": {
        "reason": { "type": "string" },
        "reusable_asset": { "type": "string" }
      }
    },
    "publish_caption": { "type": "string" },
    "hashtags": { "type": "array", "items": { "type": "string" } },
    "claim_ledger": { "type": "array", "items": { "type": "object" } },
    "scores": { "type": "object" }
  }
}
